{
    "network_disk": {
        "cleanup_days": 7
    },
    "captcha": {
        "challenge_funct": "captcha.helpers.random_char_challenge",
        "length": 4,
        "timeout": 5,
        "image_size": [
            120,
            40
        ],
        "font_size": 20,
        "background_color": "#ffffff",
        "foreground_color": "#001100",
        "noise_functions": [
            "captcha.helpers.noise_arcs",
            "captcha.helpers.noise_dots"
        ]
    },
    "jwt": {
        "access_token_expire_minutes": 60,
        "refresh_token_expire_days": 30
    },
    "rtc": {
        "app_id": "",
        "app_key": "",
        "expire_ts": 168,
        "default_room_id": "cinema_room",
        "default_user_id": "cinema_publisher",
        "token_server_host": "127.0.0.1",
        "token_server_port": 8000,
        "token_server_path": "/api/cinema/get/token",
        "rtc_env": 0,
        "enable_video": true,
        "enable_audio": true,
        "video_encoder_config": {
            "width": 1920,
            "height": 1080,
            "fps": 30,
            "max_bitrate": 4000
        }
    }
}